# Supabase: Session pooler (IPv4), порт 5432
DATABASE_URL=postgresql://postgres.xxxxx:PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
PAYLOAD_SECRET=your-random-secret-at-least-24-chars
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Database schema management
# DB_PUSH=true  — auto-sync schema without migrations (fast dev)
# DB_PUSH=false — use migrations (safe, same as prod)
DB_PUSH=true

# PostHog
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# --- Demo logins (created by seed) ---
